msgid "strangulation"
msgstr "Rear Naked Choke"

msgid "strike_description"
msgstr "The user attacks one leg and runs the pipe for the finish."

msgid "strike"
msgstr "Single Leg"

msgid "struggle_description"
msgstr "They fight back with raw instinct when no other options remain."

msgid "struggle"
msgstr "Panic Scramble"

msgid "suck_poison_description"
msgstr ""
"The user draws out the poison from their own body and infects their enemy "
"with it."

msgid "suck_poison"
msgstr "Sweat Transfer"

msgid "sudden_glow_description"
msgstr ""
"The user emits a radiant light, healing itself and restoring its stamina."

msgid "sudden_glow"
msgstr "Second Wind"

msgid "sunburst_description"
msgstr ""
"The user channels the energy of the sun, unleashing a blindingly bright "
"attack."

msgid "sunburst"
msgstr "Explosive Entry"

msgid "supernova_description"
msgstr ""
"A cataclysmic explosion of energy, dealing immense damage to all opponents."

msgid "supernova"
msgstr "Gym War"

msgid "suplex_description"
msgstr ""
"A powerful grappling move that throws the opponent to the ground, inflicting"
