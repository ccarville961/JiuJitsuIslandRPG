msgstr ""
"The user lashes out with its sharp spines or quills, striking the opponent "
"with a flurry of piercing blows, inflicting pain and damage."

msgid "spiky_strike"
msgstr "Sharp Frame"

msgid "spit_poison_description"
msgstr "Liquid death sprays from the user's venom sacs."

msgid "spit_poison"
msgstr "Toxic Coaching"

msgid "splinter_description"
msgstr ""
"The user launches a barrage of wooden splinters, blinding and damaging the "
"opponent."

msgid "splinter"
msgstr "Splitting Pass"

msgid "stabilo_description"
msgstr ""
"The user summons a barrage of sharp wooden splinters that pierce the "
"opponent."

msgid "stabilo"
msgstr "Stiff Frame"

msgid "staff_smash_description"
msgstr "The user delivers a powerful blow with its staff."

msgid "staff_smash"
msgstr "Collar Tie Snap"

msgid "stampede_description"
msgstr "A powerful charge that puts the user in motion."

msgid "stampede"
msgstr "Blast Double"

msgid "starfall_description"
msgstr ""
"A shower of celestial bodies descends upon the opponent, inflicting damage "
"and granting the user heightened focus while exhausting the opponent."

msgid "starfall"
msgstr "Flying Guard Pull"

msgid "static_field_description"
msgstr ""
"The user generates a static electric field around itself, granting it "
"increased defense."

msgid "static_field"
msgstr "Base Stabilizer"

msgid "steel_jaws_description"
msgstr ""
"The user clamps down with jaws reinforced by metal. A powerful biting "
"attack."

msgid "steel_jaws"
msgstr "Jawbreaker Grip"

msgid "stick_description"
msgstr ""
"The user uses a stick, plant part or twig to poke or smack the opponent."

msgid "stick"
msgstr "Bo Staff Grip"

msgid "sting_description"
msgstr ""
"The user inflicts a painful sting, injecting poison into the opponent's "
"body."

msgid "sting"
msgstr "Ankle Pick"

msgid "stone_rot_description"
msgstr "A sickness quickly befalls the target."

msgid "stone_rot"
msgstr "Heavy Legs"

msgid "stonehenge_description"
msgstr ""
"The user manipulates the earth, creating a ring of stones that crush the "
"opponent."

msgid "stonehenge"
msgstr "Circle Pass"

msgid "strangulation_description"
