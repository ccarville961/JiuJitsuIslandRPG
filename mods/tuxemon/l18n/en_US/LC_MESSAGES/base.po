msgid "overfeed_description"
msgstr "The user overloads the opponent with energy, slowing them down."

msgid "overfeed"
msgstr "Too Much Acai"

msgid "overgrowth_description"
msgstr "Vines lash the target, locking them in place."

msgid "overgrowth"
msgstr "Leg Entanglement"

