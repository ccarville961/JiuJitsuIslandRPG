"The user assumes a defensive stance, preparing to counter any attack with a "
"swift and powerful retaliation."

msgid "riposte"
msgstr "Counter Sweep"

msgid "rock_description"
msgstr "A heavy rock falls on the target."

msgid "rock"
msgstr "Heavy Pressure"

msgid "rocky_barrage_description"
