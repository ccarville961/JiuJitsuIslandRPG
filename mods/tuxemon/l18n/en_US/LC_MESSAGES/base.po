msgstr ""
"A flurry of feathers descends upon the opponent, inflicting multiple hits."

msgid "ten_thousand_feathers"
msgstr "Grip Spam"

msgid "terror_description"
msgstr "The target is shaking with fear, unable to pick up or use items."

msgid "terror"
msgstr "Mat Enforcer"

