msgid "scope"
msgstr "Gameplan Read"

msgid "shadow_blast_description"
msgstr ""
"The user releases a blast of negative energy, sucking life from other "
"beings."

msgid "shadow_blast"
msgstr "Sneaky Sweep"

msgid "shadow_boxing_description"
msgstr "A flurry of punches strikes the target."

msgid "shadow_boxing"
msgstr "MMA Guy Energy"

msgid "shapechange_description"
