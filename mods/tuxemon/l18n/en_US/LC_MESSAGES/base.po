msgid "sockpuppet"
msgstr "Dummy Grip"

msgid "solar_synthesis_description"
msgstr "Heals the user's health by absorbing sunlight."

msgid "solar_synthesis_fail"
msgstr "The lack of sunlight prevents the healing."

msgid "solar_synthesis"
msgstr "Breathe And Recover"

