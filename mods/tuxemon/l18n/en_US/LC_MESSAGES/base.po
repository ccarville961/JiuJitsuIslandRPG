msgstr "Adds 1,500 to a monster's XP."

msgid "tea"
msgstr "Tea"

msgid "tea_description"
msgstr "Adds 500 to a monster's XP."

msgid "revive"
msgstr "Revive"

msgid "revive_description"
msgstr "Revives knocked out Tuxemon and restores 20 HP."

msgid "tuxeball"
msgstr "Tuxeball"

msgid "tuxeball_description"
msgstr "Captures a monster."

msgid "tuxeball_earth"
msgstr "Earth Tuxeball"

msgid "tuxeball_earth_description"
msgstr "Captures more easily an Earth Tuxemon."

msgid "tuxeball_fire"
msgstr "Fire Tuxeball"

msgid "tuxeball_fire_description"
msgstr "Captures more easily a Fire Tuxemon."

msgid "tuxeball_metal"
msgstr "Metal Tuxeball"

msgid "tuxeball_metal_description"
msgstr "Captures more easily a Metal Tuxemon."

msgid "tuxeball_water"
msgstr "Water Tuxeball"

msgid "tuxeball_water_description"
msgstr "Captures more easily a Water Tuxemon."

msgid "tuxeball_wood"
msgstr "Wood Tuxeball"

msgid "tuxeball_wood_description"
msgstr "Captures more easily a Wood Tuxemon."

msgid "tuxeball_male"
msgstr "Male Tuxeball"

msgid "tuxeball_male_description"
msgstr "Captures more easily a Male Tuxemon."

msgid "tuxeball_female"
msgstr "Female Tuxeball"

msgid "tuxeball_female_description"
msgstr "Captures more easily a Female Tuxemon."

msgid "tuxeball_park"
msgstr "Park Tuxeball"

msgid "tuxeball_park_description"
msgstr "The official Park capture device. It only works inside the Park."

msgid "tuxeball_neuter"
msgstr "Neuter Tuxeball"

msgid "tuxeball_neuter_description"
msgstr "Captures more easily a Neuter Tuxemon."

msgid "tuxeball_candy"
msgstr "Candy Tuxeball"

msgid "tuxeball_candy_description"
msgstr "Captures Tuxemon and increases its level (+1) upon capture."

msgid "tuxeball_lavish"
msgstr "Lavish Tuxeball"

msgid "tuxeball_lavish_description"
msgstr ""
"The ultimate capture tool, boasting a significantly higher capture rate than"
" the Noble Tuxeball."

msgid "tuxeball_ancient"
msgstr "Ancient Tuxeball"

msgid "tuxeball_ancient_description"
msgstr ""
"This Tuxeball was made a long time ago and is capable of catching any "
"Tuxemon without fail."

msgid "tuxeball_crusher"
msgstr "Crusher Tuxeball"

msgid "tuxeball_crusher_description"
msgstr ""
"This Tuxeball breaks through defenses and increases the catch rate the "
"higher the opposing Tuxemon's defense is. It will fail to catch if a "
"protective condition is in place."

msgid "tuxeball_xero"
msgstr "Xero Tuxeball"

msgid "tuxeball_xero_description"
msgstr ""
"This odd Tuxeball increases the chance of succeeding if the opposing Tuxemon"
" is a different type than yours, but has a decreased chance if they are the "
"same type."

msgid "tuxeball_omni"
msgstr "Omni Tuxeball"

msgid "tuxeball_omni_description"
msgstr ""
"This odd Tuxeball increases the chance of succeeding if the opposing Tuxemon"
" is the same type as yours, but has a decreased chance if they are different"
" types."

msgid "tuxeball_hardened"
msgstr "Hardened Tuxeball"

msgid "tuxeball_hardened_description"
msgstr "Captures Tuxemon and it doesn't break when it fails."

msgid "tuxeball_hearty"
msgstr "Hearty Tuxeball"

msgid "tuxeball_hearty_description"
msgstr "Upon capture, the tuxemon's positive taste changes to hearty."

msgid "tuxeball_peppy"
msgstr "Peppy Tuxeball"

msgid "tuxeball_peppy_description"
msgstr "Upon capture, the tuxemon's positive taste changes to peppy."

msgid "tuxeball_refined"
msgstr "Refined Tuxeball"

msgid "tuxeball_refined_description"
msgstr "Upon capture, the tuxemon's positive taste changes to refined."

msgid "tuxeball_salty"
msgstr "Salty Tuxeball"

msgid "tuxeball_salty_description"
msgstr "Upon capture, the tuxemon's positive taste changes to salty."

msgid "tuxeball_zesty"
msgstr "Zesty Tuxeball"

msgid "tuxeball_zesty_description"
msgstr "Upon capture, the tuxemon's positive taste changes to zesty."

msgid "tuxeball_grand"
msgstr "Grand Tuxeball"

msgid "tuxeball_grand_description"
msgstr ""
"Offers an even higher capture rate than the Lavish Tuxeball, increasing the "
"chances of a successful catch."

msgid "tuxeball_majestic"
msgstr "Majestic Tuxeball"

msgid "tuxeball_majestic_description"
msgstr ""
"Boasts the highest capture rate of all, making it the ultimate choice for "
"catching even the most elusive tuxemon."

msgid "tuxeball_noble"
msgstr "Noble Tuxeball"

msgid "tuxeball_noble_description"
msgstr ""
"A moderate upgrade to the standard Tuxeball, offering a reliable capture "
"rate."

msgid "tuxeball_diurnal"
msgstr "Diurnal Tuxeball"

msgid "tuxeball_diurnal_description"
msgstr ""
"Captures more easily during daytime, but its effectiveness is significantly "
"reduced during the night."

msgid "tuxeball_nocturnal"
msgstr "Nocturnal Tuxeball"

msgid "tuxeball_nocturnal_description"
msgstr ""
"Captures more easily during nighttime, but its effectiveness is "
"significantly reduced during the day."

msgid "tuxeball_gambler"
msgstr "Gambler Tuxeball"

msgid "tuxeball_gambler_description"
msgstr ""
"This tuxeball is known for its unpredictable nature. Its catch rate "
"fluctuates wildly, with the chance of capturing a tuxemon ranging from "
"extremely low to exceptionally high."

msgid "boost_armour"
msgstr "Boost Armor"

msgid "boost_armour_description"
msgstr "For the rest of the combat, increase Armor by two stages."

msgid "boost_dodge"
msgstr "Boost Dodge"

msgid "boost_dodge_description"
msgstr "For the rest of the combat, increase Dodge by two stages."

msgid "boost_melee"
msgstr "Boost Melee"

msgid "boost_melee_description"
msgstr "For the rest of the combat, increase Melee by two stages."

msgid "boost_ranged"
msgstr "Boost Ranged"

msgid "boost_ranged_description"
msgstr "For the rest of the combat, increase Ranged by two stages."

msgid "boost_speed"
msgstr "Boost Speed"

msgid "boost_speed_description"
msgstr "For the rest of the combat, increase Speed by two stages."

msgid "raise_armour"
msgstr "Raise Armor"

msgid "raise_armour_description"
msgstr "Learn the hardness of the diamond. Increase Armor by 5%."

msgid "raise_dodge"
msgstr "Raise Dodge"

msgid "raise_dodge_description"
msgstr "Learn the iridescence of the opal. Increase Dodge by 5%."

msgid "raise_hp"
msgstr "Raise HP"

msgid "raise_hp_description"
msgstr "Learn the bulk and abundance of quartz. Increase HP by 5%."

msgid "raise_melee"
msgstr "Raise Melee"

msgid "raise_melee_description"
msgstr "Learn the anger of the ruby. Increase Melee by 5%."

msgid "raise_ranged"
msgstr "Raise Ranged"

msgid "raise_ranged_description"
msgstr "Learn the aim of the emerald. Increase Ranged by 5%."

msgid "raise_speed"
msgstr "Raise Speed"

msgid "raise_speed_description"
msgstr "Learn the reflexes of the spinel. Increase Speed by 5%."

msgid "alpha_seep"
msgstr "Alpha Seep"

msgid "alpha_seep_description"
msgstr ""
"Thick, mucosal secretion harvested from the scent glands of apex predators "
"at the peak of their territorial cycle."

msgid "fishing_rod"
msgstr "Fishing Rod"

msgid "fishing_rod_description"
msgstr "Catch fish."

msgid "poseidon"
msgstr "Poseidon"

msgid "poseidon_description"
msgstr "Professional fishing rod."

msgid "neptune"
msgstr "Neptune"

msgid "neptune_description"
msgstr "Advanced fishing rod."

msgid "hatchet"
msgstr "Hatchet"

msgid "hatchet_description"
msgstr "Cut down pesky logs with the Hatchet."

msgid "surfboard"
msgstr "Surfboard"

msgid "surfboard_description"
msgstr "From your Mom. It lets you travel faster."

msgid "gold_pass"
msgstr "Gold Pass"

msgid "gold_pass_description"
msgstr "Enjoy the Cathedral's deluxe services."

msgid "dojo_pass"
msgstr "Dojo Pass"

msgid "dojo_pass_description"
msgstr "Admit one to the Dojo of the Elements."

msgid "book_wishes"
msgstr "Book of Wishes"

msgid "book_wishes_description"
msgstr "The Achievement Maniac's list of achievements for you to attempt."

msgid "earthmover_key"
msgstr "Earthmover Key"

msgid "earthmover_key_description"
msgstr "Could come in handy if there's a giant earthmover blocking the path."

msgid "sledgehammer"
msgstr "Sledgehammer"

msgid "sledgehammer_description"
msgstr "Smash apart gray boulders."

msgid "shammer_fossil"
msgstr "Shammer Fossil"

msgid "shammer_fossil_description"
msgstr "It looks like the skull of an ancient dog, but it's hard as stone."

msgid "rhincus_fossil"
msgstr "Rhincus Fossil"

msgid "rhincus_fossil_description"
msgstr "It looks like the skull of a toothed bird, but it's hard as stone."

msgid "nu_phone"
msgstr "Nu Phone"

msgid "nu_phone_description"
msgstr "You can do a lot with this, e.g. phone home."

msgid "bivouac"
msgstr "Bivouac"

msgid "bivouac_description"
msgstr "Rest as if you were at a proper healing center. Consumed on use."

msgid "drone"
msgstr "Drone"

msgid "drone_description"
msgstr "Switch out one tuxemon on your team for one in storage."

msgid "spyder_pass"
msgstr "Spyder Pass"

msgid "spyder_pass_description"
msgstr ""
"This should let you in to places only Spyder conspirators are meant to go."

msgid "app_radio"
msgstr "Radio App"

msgid "app_radio_description"
msgstr "Tune in to local broadcasts, quest updates, and ambient chatter from across the region."

msgid "app_banking"
msgstr "Bank App"

msgid "app_banking_description"
msgstr "Access your funds here whenever you're in a town."

msgid "app_contacts"
msgstr "Contacts App"

msgid "app_contacts_description"
msgstr "Call your friends and battle the people of your choice."

msgid "app_map"
msgstr "Map App"

msgid "app_map_description"
msgstr "Use this on your phone to see where you are."

msgid "app_renaming"
msgstr "Renaming App"

msgid "app_renaming_description"
msgstr "Give your Tuxemon a fresh identity with a new nameâ€”make it truly yours!"

msgid "app_tuxepedia"
msgstr "Tuxepedia App"

msgid "app_tuxepedia_description"
msgstr ""
"Keep track of information about Tuxemon here, and share it with the world."

msgid "p_trepidation"
msgstr "Trepidation"

msgid "p_trepidation_description"
msgstr ""
"Painting 'Trepidation', medium: oil on canvas. Hand-signed by the artist."

msgid "p_starry_night"
msgstr "Starry Night"

msgid "p_starry_night_description"
msgstr ""
"Painting 'Starry, Starry, Starry Night', medium: oil on canvas. Hand-signed "
"by the artist."

msgid "p_monsters_eyes"
msgstr "Eyes Meet"

msgid "p_monsters_eyes_description"
msgstr ""
"Painting 'Monsters' Eyes Meet', medium: oil on canvas. Hand-signed by the "
"artist."

msgid "ancient_egg"
msgstr "Ancient Egg"

msgid "ancient_egg_description"
msgstr "A peculiar egg. If you plant it, maybe it will hatch."

msgid "restoration"
msgstr "Restoration"

msgid "restoration_description"
msgstr "Remove any condition currently affecting the target."

msgid "cureall"
msgstr "Cureall"

msgid "cureall_description"
msgstr "Heals your tuxemon to full health and removes any conditions."

msgid "escape_key"
msgstr "Escape Key"

msgid "escape_key_description"
msgstr "Slip out the back door."

# Craft
msgid "unknown_object"
msgstr "Unknown Object"

msgid "unknown_object_description"
msgstr "Unknown origin and use. Must be identified before being applied."

msgid "bite_of_despair"
msgstr "Bite Of Despair"

msgid "bite_of_despair_description"
msgstr "Its scent hits first. Then the flavor finishes the job mercilessly."

msgid "whispersoup"
msgstr "Whispersoup"

msgid "whispersoup_description"
msgstr "The ladle trembles as you serve. No one speaks of what happened next."

msgid "inferno_custard"
msgstr "Inferno Custard"

msgid "inferno_custard_description"
msgstr "Too hot to eat. Too cursed to ignore. The bowl crackles with regret."

msgid "dread_omelette"
msgstr "Dread Omelette"

msgid "dread_omelette_description"
msgstr "It defies the laws of texture and taste. Even your utensils rebel."

# Ingredients
msgid "meal_dust"
msgstr "Meal Dust"

msgid "meal_dust_description"
msgstr ""
"A fine blend of skyfield grains crushed under moonlight. Flexible, "
"lightweight, and essential to anything baked, folded, or fried."

msgid "sweetroot"
msgstr "Sweetroot"

msgid "sweetroot_description"
msgstr ""
"Glowing tubers harvested from whispering forest hollows. Sweet and mellow "
"with a hint of citrus zingâ€”ideal for desserts or tangy toppings."

msgid "mistflour_eggs"
msgstr "Mistflour Eggs"

msgid "mistflour_eggs_description"
msgstr ""
"Mysterious eggs laid by cloud roosting avians. Soft-shelled and full of "
"magical air, they fluff and bind dishes like a dream."

msgid "suncrust_butter"
msgstr "Suncrust Butter"

msgid "suncrust_butter_description"
msgstr ""
"Golden-rich cream pressed from sun-petal blooms. Warm, smooth, and faintly "
"herbalâ€”used to soften, shine, and enrich any dish."

msgid "crackle_salt"
msgstr "Crackle Salt"

msgid "crackle_salt_description"
msgstr ""
"Sparkling minerals mined in echoing caves. Adds bite and shimmer to savory "
"recipes, and sometimes pops mid-bite!"

msgid "starpepper"
msgstr "Starpepper"

msgid "starpepper_description"
msgstr ""
"Tiny glowing berries that ripen only under starlight. Fiery but sweet, they "
"burn with a warmth that tickles rather than scorches."

msgid "sky_feather"
msgstr "Sky Feather"

msgid "sky_feather_description"
msgstr ""
"Plucked from the molting of breezebirds after migration. Delicate, light, "
"and a crisp favorite for peppy platings."

msgid "stonefruit_bulbs"
msgstr "Stonefruit Bulbs"

msgid "stonefruit_bulbs_description"
msgstr ""
"Hearty root-plants from volcanic valleys. Firm like meat, flavorful like "
"mushroom, and deeply satisfying."

msgid "field_greens"
msgstr "Field Greens"

msgid "field_greens_description"
msgstr ""
"Wild leaves that shift color with the wind. Bright, peppery, and often eaten"
" freshâ€”or warmed just enough to curl."

msgid "beastmoss"
msgstr "Beastmoss"

msgid "beastmoss_description"
msgstr ""
"Thick moss found clinging to ancient creatures and sacred stones. Chewy, "
"earthy, and perfect in flakey wraps or hearty pies."

msgid "glowfat"
msgstr "Glowfat"

msgid "glowfat_description"
msgstr ""
"Rendered oil from luminous vines or docile beastbloom. Silky texture with a "
"buttery aromaâ€”used for cooking or glazing."

msgid "moo_bloom"
msgstr "Moo Bloom"

msgid "moo_bloom_description"
msgstr ""
"Milky nectar tapped from docile meadow beasts. Smooth and comforting with "
"notes of honeygrass and sugarstem."

msgid "zestsap"
msgstr "Zestsap"

msgid "zestsap_description"
msgstr ""
"Electrified syrup drawn from zingfruit trees. Sharp, citrus-like and "
"wonderfully alive on the tongueâ€”used to wake up sleepy flavors."

msgid "zestroot_wraps"
msgstr "Zestroot Wraps"

msgid "zestroot_wraps_description"
msgstr ""
"Flexible shoots used as edible wrappers. Springy and infused with latent "
"spiceâ€”favored in soft, foldable dishes."

msgid "root_beast_bark"
msgstr "Root Beast Bark"

msgid "root_beast_bark_description"
msgstr ""
"Strips of hardened plant flesh shaped like ribs. Smoky and fibrous with a "
"primal umamiâ€”seasoned like a carnivore's dream, but plant-based."

msgid "flamehorn_shank"
msgstr "Flamehorn Shank"

msgid "flamehorn_shank_description"
msgstr ""
"Thick slices harvested from flamehorn floraâ€”giant, non-sentient fireplants "
"cultivated for seared cuts. Bold, charred, and packed with bite."

msgid "spice_dust"
msgstr "Spice Dust"

msgid "spice_dust_description"
msgstr ""
"Crushed crystals infused with latent fire and zingfruit essence. Flickers on"
" the tongue and wakes up any dish with a dazzling spark."

# Dishes
msgid "rub_pork_chops"
msgstr "Rub Pork Chops"

msgid "rub_pork_chops_description"
msgstr ""
"Root beast bark slices coated in crackle dust. Smoky, spicy, and "
"fierceâ€”seasoned like primal meat, but purely plant-powered."

msgid "mille_feuille"
msgstr "Mille-Feuille"

msgid "mille_feuille_description"
msgstr ""
"Layered pastry made with mistflour and moo bloom cream. Rich, delicate, and "
"stacked with sweetness."

msgid "cheesecake"
msgstr "Cheesecake"

msgid "cheesecake_description"
msgstr ""
"Soft moo bloom cake with glowfat swirl. Creamy and luxurious with a mellow "
"sparkle."

msgid "cream_puffs"
msgstr "Cream Puffs"

msgid "cream_puffs_description"
msgstr ""
"Sweetroot puffs filled with enchanted cream. Light, airy, and wickedly "
"indulgent."

msgid "crepes"
msgstr "Crepes"

msgid "crepes_description"
msgstr ""
"Thin meal dust crepes wrapped around shimmer filling. Graceful, sweet, and "
"just a little peppery."

msgid "rub_steak"
msgstr "Rub Steak"

msgid "rub_steak_description"
msgstr ""
"Flamehorn-style roast rubbed with spice crystals. Bold, seared, and humming "
"with heat."

msgid "meatballs"
msgstr "Meatballs"

msgid "meatballs_description"
msgstr ""
"Crumbled stonefruit bulb balls in zestsap glaze. Hearty, tangy, and "
"magically satisfying."

msgid "shell_tacos"
msgstr "Shell Tacos"

msgid "shell_tacos_description"
msgstr ""
"Field wrap tacos with zestroot fillings and moo bloom sauce. Fresh, springy,"
" and packed with zip."

msgid "potato_casserole"
msgstr "Potato Casserole"

msgid "potato_casserole_description"
msgstr ""
"Sweetroot and mistflour layers baked in zestsap. Warm and citrusy with a "
"soft bite."

msgid "phyllo"
msgstr "Phyllo"

msgid "phyllo_description"
msgstr ""
"Flaky wrap filled with tangy beastmoss. Delicate layers with a bold, earthy "
"center."

msgid "croissants"
msgstr "Croissants"

msgid "croissants_description"
msgstr ""
"Buttery suncrust croissants with zesty dust. Crisp, golden, and lightly "
"electrified."

msgid "rub_chicken"
msgstr "Rub Chicken"

msgid "rub_chicken_description"
msgstr ""
"Sky feather cutlets rubbed in starpepper mix. Light, crispy, and boldly "
"seasoned."

msgid "potato_fries"
msgstr "Potato Fries"

msgid "potato_fries_description"
msgstr ""
"Sweetroot fries with magical salt blend. Crunchy, glowing, and surprisingly "
"feisty."

msgid "pretzels"
msgstr "Pretzels"

msgid "pretzels_description"
msgstr ""
"Twisted field grain bites with starpepper hints. Salty, chewy, and playfully"
" spicy."

msgid "mashed_potatoes"
msgstr "Mashed Potatoes"

msgid "mashed_potatoes_description"
msgstr ""
"Soft root mash with crackle salt and moo bloom cream. Comforting with a "
"fizzy edge."

msgid "rub_ribs"
msgstr "Rub Ribs"

msgid "rub_ribs_description"
msgstr ""
"Stonefruit bulb ribs coated in crackle spices. Meaty texture and satisfying "
"pop."

msgid "pie"
msgstr "Pie"

msgid "pie_description"
msgstr ""
"Golden pie crust filled with beastmoss stew. Hearty, flaky, and deeply "
"savory."

msgid "honey_cake"
msgstr "Honey Cake"

msgid "honey_cake_description"
msgstr ""
"Moist sweetroot cake infused with shimmer dust. Sweet, spicy, and full of "
"bounce."

msgid "souffle"
msgstr "SoufflÃ©"

msgid "souffle_description"
msgstr ""
"Airy glowfat soufflÃ© puffed with zestsap. Light, tangy, and dreamlike on the"
" tongue."

msgid "hash"
msgstr "Hash"

msgid "hash_description"
msgstr ""
"Warm hash of root veggies and enchanted herbs. Earthy comfort with a peppery"
" kick."

msgid "pita"
msgstr "Pita"

msgid "pita_description"
msgstr ""
"Dry crispbread with a zesty spice dust spread. Simple, snappy, and full of "
"flavor."

msgid "pastry"
msgstr "Pastry"

msgid "pastry_description"
msgstr ""
"Flaky pastry filled with a spicy sweetroot swirl. Buttery folds with a "
"firecracker heart."

msgid "pudding"
msgstr "Pudding"

msgid "pudding_description"
msgstr ""
"Creamy sweetroot pudding with a tangy glow. Smooth and citrusy with a gentle"
" shimmer."

msgid "pancakes"
msgstr "Pancakes"

msgid "pancakes_description"
msgstr ""
"Fluffy sky-grain cakes topped with shimmer zest. Soft, warm, and joyfully "
"bright."

msgid "wings"
msgstr "Wings"

msgid "wings_description"
msgstr ""
"Crispy flying-beast style bites with magical heat. Bold, sizzling, and bite-"
"sized bravery."

# Research Tools
msgid "mystery_analyzer"
msgstr "Mystery Analyzer"

msgid "mystery_analyzer_description"
msgstr "A chunky scanner that beeps joyfully when decoding artifacts."

msgid "buzz_resonator"
msgstr "Buzz Resonator"

msgid "buzz_resonator_description"
msgstr "Detects insect-like tuxemon vibrations and hive signals."

msgid "pollen_decoder"
msgstr "Pollen Decoder"

msgid "pollen_decoder_description"
msgstr "Reads biological residue and pollen from nature-bound tuxemon."

msgid "researcher_stylus"
msgstr "Researcher's Stylus"

msgid "researcher_stylus_description"
msgstr "Interfaces with digital and ancient data carriers."

msgid "tachyon_collector"
msgstr "Tachyon Collector"

msgid "tachyon_collector_description"
msgstr ""
"Captures and measures the presence of tachyons emitted by time manipulation."

msgid "archeologist_sensor"
msgstr "Archeologist's Sensor"

msgid "archeologist_sensor_description"
msgstr "Detects energy signatures in rare, mysterious artifacts."

msgid "aura_tuner"
msgstr "Aura Tuner"

msgid "aura_tuner_description"
msgstr "Measures psychic and emotional energy near mysterious objects."

msgid "starlight_lens"
msgstr "Starlight Lens"

msgid "starlight_lens_description"
