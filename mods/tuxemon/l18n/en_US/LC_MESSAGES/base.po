msgid "suplex"
msgstr "Suplex"

msgid "surf_description"
msgstr "A massive wave crashes down upon the opponent."

msgid "surf"
msgstr "Wave Sweep"

msgid "surge_description"
msgstr "A powerful electric discharge that shocks the opponent."

msgid "surge"
msgstr "Explosive Bridge"

msgid "sylvan_description"
msgstr ""
"The user summons the power of nature, transforming the opponent into a "
"wooden puppet."

msgid "sylvan"
msgstr "Tree Trunk Base"

msgid "tail_lash_description"
msgstr "The user lashes out with their tail or tail like appendage."

msgid "tail_lash"
msgstr "Leg Pummel"

msgid "take_cover_description"
msgstr "The user assumes a defensive stance, increasing its accuracy."

msgid "take_cover"
msgstr "Defensive Shell"

msgid "taunt_description"
msgstr "The user applies silent pressure by looking like they know exactly what you did wrong."

msgid "taunt"
msgstr "Mat Enforcer Stare"

